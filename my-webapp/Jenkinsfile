pipeline {
	agent any

		parameters {
        string(name: 'JIRA_KEY', description: 'Enter Jira Issue Key (e.g., DSO-2)')
    	}

		tools {
			maven 'maven-3.9.11'
				jdk 'java-21'
		}

	environment {
			TOMCAT_URL = "http://192.168.161.4:8080"
			APP_NAME   = "my-webapp"

			SONAR_HOST_URL = "https://sonarcloud.io"
			SONAR_ORG      = "dso-nkm"      
			SONAR_PROJECT  = "my-webapp"

			REPOSITORY_URL = "http://192.168.161.7:8081/repository"
			REPOSITORY_REPO      = "maven-releases"
			BUILD_NUMBER    = "${env.BUILD_NUMBER}"
			DOCKER_IMAGE    = "mnaveenk85/my-webapp"
	}

	stages {
		stage('Cleanup Workspace') {
			steps {
				script {
					cleanWs()
				}
			}
		}	

		stage('Checkout') {
			steps {
				git branch: 'main', url: 'https://github.com/naveenkumarmuppala/myDevOpsProject2025.git'
			}
		}

		stage('Get Jira Key') {
            steps {
                script {
                    def commitMsg = sh(
                        script: "git log -1 --pretty=%B",
                        returnStdout: true
                    ).trim()

                    echo "Commit Message: ${commitMsg}"

                    def matcher = (commitMsg =~ /([A-Z]+-\d+)/)

                    if (matcher) {
                        env.JIRA_KEY = matcher[0][0]
                        echo "Extracted Jira Key: ${env.JIRA_KEY}"
                    } else {
                        error "No Jira key found in commit message!"
                    }
                }
            }
        }

		stage('Build') {
			steps {
				sh """
					cd my-webapp
					mvn clean package
					"""
			}
			post {
				always {
					jiraSendBuildInfo site: 'naveen-kumar-muppala.atlassian.net'
				} 
			}
		}

		stage('Upload to Nexus') {
			steps {
				withCredentials([usernamePassword(credentialsId: 'nexus-creds', usernameVariable: 'NEXUS_USER', passwordVariable: 'NEXUS_PASS')]) {
					sh """
						curl -v -u${NEXUS_USER}:${NEXUS_PASS} \
						--upload-file my-webapp/target/${APP_NAME}.war \
						"${REPOSITORY_URL}/${REPOSITORY_REPO}/com/example/${APP_NAME}/${BUILD_NUMBER}/${APP_NAME}-${BUILD_NUMBER}.war"
					"""
				}
			}
		}

		stage('SonarCloud Analysis') {
			steps {
				withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
					sh """
						cd my-webapp
						mvn sonar:sonar \
						-Dsonar.projectKey=${SONAR_PROJECT} \
						-Dsonar.organization=${SONAR_ORG} \
						-Dsonar.host.url=${SONAR_HOST_URL} \
						-Dsonar.login=$SONAR_TOKEN
						"""
				}
			}
		}

		stage('Build & Push Docker Image') {
    		steps {
        		script {
            		withCredentials([usernamePassword(
                	credentialsId: 'docker-creds',
                	usernameVariable: 'DOCKER_USER',
                	passwordVariable: 'DOCKER_PASS'
            )]) 	{

                	sh """
                 		# Build Docker image
                    	docker build -t ${DOCKER_IMAGE}:${BUILD_NUMBER} -t ${DOCKER_IMAGE}:latest ./my-webapp

                    	# Login to Docker Hub
                    	echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin

                    	# Push images
                    	docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                    	docker push ${DOCKER_IMAGE}:latest
                	"""
                	}
            	}
        	}
    	}

		stage('Download from Nexus') {
			steps {
				withCredentials([usernamePassword(credentialsId: 'nexus-creds', usernameVariable: 'NEXUS_USER', passwordVariable: 'NEXUS_PASS')]) {
					sh """
						cd my-webapp
						mkdir -p downloaded-artifacts

						curl -v -u${NEXUS_USER}:${NEXUS_PASS} -O \
						"${REPOSITORY_URL}/${REPOSITORY_REPO}/com/example/${APP_NAME}/${BUILD_NUMBER}/${APP_NAME}-${BUILD_NUMBER}.war"

						mv ${APP_NAME}-${BUILD_NUMBER}.war downloaded-artifacts/
					"""
				}
			}
		}
		stage('Deploy to Tomcat') {
			steps {
				withCredentials([usernamePassword(credentialsId: 'tomcat-creds', usernameVariable: 'TOMCAT_USER', passwordVariable: 'TOMCAT_PASS')]) {
					sh """
						curl -u $TOMCAT_USER:$TOMCAT_PASS \
						-T my-webapp/downloaded-artifacts/${APP_NAME}-${BUILD_NUMBER}.war \
						"$TOMCAT_URL/manager/text/deploy?path=/${APP_NAME}&update=true"
						"""
				}
			}
			post {
				success {
					// send deployment info (include environment info as needed)
					jiraSendDeploymentInfo site: 'naveen-kumar-muppala.atlassian.net',
							       environmentId: 'dev-env',
							       environmentName: 'Development',
							       environmentType: 'development',
							       issueKeys: [env.JIRA_KEY]
				}
			}

		}
	}
	post {
		success {
			script {
				// ✅ Update labels on the issue
				jiraEditIssue(
						site: 'jira-jenkins',
						idOrKey: env.JIRA_KEY,
						issue: [
						fields: [
						labels: ['deployed']
						]
						]
					    )

					// ✅ Transition the issue
					jiraTransitionIssue(
							site: 'jira-jenkins',
							idOrKey: env.JIRA_KEY,
							input: [
							transition: [id: '31']
							]
							)
			}
		}
		
    	always {
        	script {
            	def jobName = env.JOB_NAME
            	def buildNumber = env.BUILD_NUMBER
            	def pipelineStatus = currentBuild.result ?: 'UNKNOWN'
            	def bannerColor = pipelineStatus.toUpperCase() == 'SUCCESS' ? 'green' : 'red'

            	def body = """
                	<html>
                	<body>
                	<div style="border: 4px solid ${bannerColor}; padding: 10px;">
                	<h2>${jobName} - Build ${buildNumber}</h2>
                	<div style="background-color: ${bannerColor}; padding: 10px;">
                	<h3 style="color: white;">Pipeline Status: ${pipelineStatus.toUpperCase()}</h3>
                	</div>
                	<p>Check the <a href="${BUILD_URL}">console output</a>.</p>
                	</div>
                	</body>
                	</html>
            	"""

            	emailext (
                	subject: "${jobName} - Build ${buildNumber} - ${pipelineStatus.toUpperCase()}",
                	body: body,
                	to: 'muppala.devops@gmail.com',
                	from: 'devopsAdmin@dso.com',
                	replyTo: 'devopsAdmin@dso.com',
                	mimeType: 'text/html')
        	}
    	}
	}
}
